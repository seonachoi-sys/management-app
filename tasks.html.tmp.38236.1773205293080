// ============================================================
// UTILITY FUNCTIONS
// ============================================================
const TODAY = new Date();

function parseDate(str) {
  if (!str) return null;
  return new Date(str);
}

function formatDate(str) {
  if (!str) return '-';
  const d = new Date(str);
  if (isNaN(d.getTime())) return '-';
  return (d.getMonth()+1) + '/' + d.getDate();
}

function getTaskStatus(task) {
  if (task.progress === 100 || task.completionDate) return '완료';
  const dl = parseDate(task.deadline);
  if (dl) {
    const diffDays = (dl - TODAY) / (1000*60*60*24);
    if (diffDays < 0 && task.progress < 100 && !task.completionDate) return '지연';
    if (diffDays >= 0 && diffDays <= 3 && task.progress < 100) return '주의';
  }
  if (task.progress > 0) return '진행중';
  return '미착수';
}

function statusBadgeClass(status) {
  switch(status) {
    case '완료': return 'badge-done';
    case '진행중': return 'badge-prog';
    case '지연': return 'badge-late';
    case '주의': return 'badge-warn';
    default: return 'badge-todo';
  }
}

function priBadgeClass(pri) {
  switch(pri) {
    case '1순위': return 'badge-p1';
    case '2순위': return 'badge-p2';
    case '3순위': return 'badge-p3';
    default: return 'badge-p4';
  }
}

function progFillClass(p) {
  if (p >= 100) return 'pf-done';
  if (p >= 50) return 'pf-mid';
  if (p > 0) return 'pf-low';
  return 'pf-zero';
}

function getOwners(ownerStr) {
  return ownerStr.split(',').map(s => s.trim());
}

function filterTasks(month) {
  if (month === 'all') return taskData;
  return taskData.filter(t => t.month === parseInt(month));
}

