  let html = `
    <div class="report-section">
      <h3>CEO 주간 보고 - 경영관리팀</h3>
      <div class="report-date">보고 기간: ${fmtD(weekStart)} (월) ~ ${fmtD(nextWeekEnd)} (금) | 작성일: ${fmtD(now)}</div>
    </div>
  `;

  // Section 1: Completed tasks
  html += `<div class="report-section"><h3>완료 업무 (${doneTasks.length}건)</h3>`;
  depts.forEach(dept => {
    const deptDone = doneTasks.filter(t => t.dept === dept);
    if (deptDone.length === 0) return;
    html += `<h4>${dept}</h4>`;
    deptDone.forEach(t => {
      html += `<div class="report-item"><span class="badge-status badge-done">완료</span> ${t.content} <span style="color:#888;font-size:11px">(${t.owner}, 완료: ${formatDate(t.completionDate)})</span></div>`;
    });
  });
  html += '</div>';

  // Section 2: In progress
  html += `<div class="report-section"><h3>진행 중 업무 (${inProgress.length}건)</h3>`;
  depts.forEach(dept => {
    const deptProg = inProgress.filter(t => t.dept === dept);
    if (deptProg.length === 0) return;
    html += `<h4>${dept}</h4>`;
    deptProg.forEach(t => {
      html += `<div class="report-item"><span class="badge-status badge-prog">진행중</span> ${t.content} <span style="color:#888;font-size:11px">(${t.owner}, 진척: ${t.progress}%, 마감: ${formatDate(t.deadline)})</span></div>`;
    });
  });
  html += '</div>';

  // Section 3: Issues (late + warn)
  if (issuesTasks.length > 0) {
    html += `<div class="report-section"><h3>지연 / 이슈 업무 (${issuesTasks.length}건)</h3>`;
    depts.forEach(dept => {
      const deptIssue = issuesTasks.filter(t => t.dept === dept);
      if (deptIssue.length === 0) return;
      html += `<h4>${dept}</h4>`;
      deptIssue.forEach(t => {
        const st = t.status;
        html += `<div class="report-item"><span class="badge-status ${statusBadgeClass(st)}">${st}</span> ${t.content} <span style="color:#888;font-size:11px">(${t.owner}, 진척: ${t.progress}%, 마감: ${formatDate(t.deadline)})</span>
        ${t.statusDesc ? `<br><span style="color:#e65100;font-size:11px">${t.statusDesc}</span>` : ''}
        </div>`;
      });
    });
    html += '</div>';
  }

  // Section 4: Decisions needed
  if (decisions.length > 0) {
    html += `<div class="report-section"><h3>결정 필요 사항 (${decisions.length}건)</h3>`;
    decisions.forEach(t => {
      html += `<div class="report-highlight"><strong>${t.dept}</strong> - ${t.content}<br><span style="color:#c62828">결정사항: ${t.decision}</span> <span style="color:#888;font-size:11px">(담당: ${t.owner})</span></div>`;
    });
    html += '</div>';
  }

  // Section 5: Meetings
  if (meetings.length > 0) {
    html += `<div class="report-section"><h3>미팅 요청 (${meetings.length}건)</h3>`;
    meetings.forEach(t => {
      html += `<div class="report-item"><strong>${t.dept}</strong> - ${t.content}: <span style="color:#1a237e;font-weight:600">${t.meeting}</span></div>`;
    });
    html += '</div>';
  }

  // Section 6: Next 2 weeks plan
  html += `<div class="report-section"><h3>향후 2주 계획 (${upcomingTasks.length}건)</h3>`;
  depts.forEach(dept => {
    const deptUp = upcomingTasks.filter(t => t.dept === dept);
    if (deptUp.length === 0) return;
    html += `<h4>${dept}</h4>`;
    deptUp.forEach(t => {
      const st = getTaskStatus(t);
      html += `<div class="report-item"><span class="badge-status ${statusBadgeClass(st)}">${st}</span> ${t.content} <span style="color:#888;font-size:11px">(${t.owner}, 마감: ${formatDate(t.deadline)}, 진척: ${t.progress}%)</span></div>`;
    });
  });
  html += '</div>';

  document.getElementById('weeklyReport').innerHTML = html;
}

function printReport() {
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('print-target'));
  document.getElementById('panel3').classList.add('print-target');
  window.print();
}

