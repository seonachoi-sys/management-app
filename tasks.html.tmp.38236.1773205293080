function populateFilters() {
  // Get available months
  const months = [...new Set(taskData.map(t => t.month))].sort((a, b) => a - b);

  // Populate month selectors
  const dashMonthSel = document.getElementById('dashMonth');
  const listMonthSel = document.getElementById('listMonth');

  const dashVal = dashMonthSel.value;
  const listVal = listMonthSel.value;

  let monthOptions = '<option value="all">전체</option>';
  months.forEach(m => {
    monthOptions += `<option value="${m}">${m}월</option>`;
  });

  dashMonthSel.innerHTML = monthOptions;
  listMonthSel.innerHTML = monthOptions;

  // Restore previous selection if still valid
  if (dashVal) dashMonthSel.value = dashVal;
  if (listVal) listMonthSel.value = listVal;

  // Populate person filter
  const allOwners = new Set();
  taskData.forEach(t => {
    getOwners(t.owner).forEach(o => { if (o) allOwners.add(o); });
  });
  const personSel = document.getElementById('filterPerson');
  const personVal = personSel.value;
  personSel.innerHTML = '<option value="all">전체</option>' +
    [...allOwners].sort().map(p => `<option value="${p}">${p}</option>`).join('');
