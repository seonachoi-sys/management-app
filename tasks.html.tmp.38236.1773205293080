let activePriDropdown = null;

function renderTaskList() {
  const month = document.getElementById('listMonth').value;
  const person = document.getElementById('filterPerson').value;
  const dept = document.getElementById('filterDept').value;
  const status = document.getElementById('filterStatus').value;
  const priority = document.getElementById('filterPriority').value;

  let tasks = filterTasks(month);
  if (person !== 'all') tasks = tasks.filter(t => getOwners(t.owner).includes(person));
  if (dept !== 'all') tasks = tasks.filter(t => t.dept === dept);
  if (status !== 'all') tasks = tasks.filter(t => getTaskStatus(t) === status);
  if (priority !== 'all') tasks = tasks.filter(t => t.priority === priority);

  // Sort by priority level then deadline proximity
  const priOrder = {'1순위':1,'2순위':2,'3순위':3,'4순위':4};
  tasks.sort((a,b) => {
    const pa = priOrder[a.priority] || 9;
    const pb = priOrder[b.priority] || 9;
    if (pa !== pb) return pa - pb;
    const da = parseDate(a.deadline);
    const db = parseDate(b.deadline);
    if (da && db) return da - db;
    return 0;
  });

  // Group by 구분
  const groups = {};
  const groupOrder = [];
  tasks.forEach(t => {
    const key = t.dept || '기타';
    if (!groups[key]) { groups[key] = []; groupOrder.push(key); }
    groups[key].push(t);
  });

  let html = '';
  let rowNum = 1;
  groupOrder.forEach(grp => {
    html += `<tr class="group-header-row"><td colspan="10">${grp}</td></tr>`;
    groups[grp].forEach(t => {
      const st = getTaskStatus(t);
      const idx = taskData.indexOf(t);
      html += `<tr>
        <td>${rowNum++}</td>
        <td>${t.dept}</td>
        <td class="left">${t.content}</td>
        <td>${t.owner}</td>
        <td>
          <span class="badge-pri ${priBadgeClass(t.priority)}" onclick="togglePriDropdown(event, ${idx})" id="pri-${idx}">
            ${t.priority}
          </span>
        </td>
        <td>${formatDate(t.start)}</td>
        <td>${formatDate(t.deadline)}</td>
        <td>
          <div class="prog-bar"><div class="prog-fill ${progFillClass(t.progress)}" style="width:${t.progress}%"></div></div>
          ${t.progress}%
        </td>
        <td><span class="badge-status ${statusBadgeClass(st)}">${st}</span></td>
        <td class="left">${t.statusDesc || '-'}</td>
      </tr>`;
    });
  });
  document.getElementById('taskBody').innerHTML = html;
}

function togglePriDropdown(e, idx) {
  e.stopPropagation();
  closePriDropdown();
  const span = document.getElementById('pri-' + idx);
  const rect = span.getBoundingClientRect();
  const dropdown = document.createElement('div');
  dropdown.className = 'pri-dropdown';
  dropdown.style.position = 'fixed';
  dropdown.style.top = (rect.bottom + 2) + 'px';
  dropdown.style.left = rect.left + 'px';

  ['1순위','2순위','3순위','4순위'].forEach(pri => {
    const d = document.createElement('div');
    d.textContent = pri;
    d.className = priBadgeClass(pri);
    d.onclick = function(ev) {
      ev.stopPropagation();
      taskData[idx].priority = pri;
      // Save override locally
      priorityOverrides[idx] = {
        month: taskData[idx].month,
        content: taskData[idx].content,
        priority: pri
      };
      closePriDropdown();
      renderTaskList();
    };
    dropdown.appendChild(d);
  });
  document.body.appendChild(dropdown);
  activePriDropdown = dropdown;
}

function closePriDropdown() {
  if (activePriDropdown) {
    activePriDropdown.remove();
    activePriDropdown = null;
  }
}

document.addEventListener('click', closePriDropdown);

