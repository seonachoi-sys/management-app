<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>업무관리 대시보드</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:'Malgun Gothic','Apple SD Gothic Neo',sans-serif;background:#f7f6fb;color:#3a3a4a;font-size:13px}
.header{background:linear-gradient(135deg,#7c83c9,#a0b4f0);color:#fff;padding:20px 28px;box-shadow:0 2px 8px rgba(124,131,201,.25)}
.header h1{font-size:22px}
.header p{font-size:12px;opacity:.8;margin-top:3px}
.container{max-width:1500px;margin:0 auto;padding:20px}
.tabs{display:flex;gap:4px;margin-bottom:18px;flex-wrap:wrap}
.tab{padding:10px 20px;border:none;background:#fff;border-radius:8px 8px 0 0;cursor:pointer;font-weight:600;font-size:13px;font-family:inherit;border-bottom:3px solid transparent;transition:.2s}
.tab.active{background:#8b93d1;color:#fff;border-bottom-color:#f4a8c1}
.tab:hover:not(.active){background:#ede7f6}
.panel{display:none}
.panel.active{display:block}

/* Cards */
.cards{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:14px;margin-bottom:20px}
.card{background:#fff;border-radius:10px;padding:16px;box-shadow:0 1px 3px rgba(0,0,0,.06);border-left:4px solid #b0b7e8}
.card.green{border-left-color:#a5d6b0}
.card.blue{border-left-color:#a0c4f0}
.card.red{border-left-color:#f0a0a0}
.card.orange{border-left-color:#f5c89a}
.card .lb{font-size:12px;color:#888;margin-bottom:4px}
.card .vl{font-size:28px;font-weight:700}
.card.green .vl{color:#5cb878}
.card.blue .vl{color:#6ba3d6}
.card.red .vl{color:#d97070}
.card.orange .vl{color:#e0935a}

/* Section */
.section-title{font-size:15px;font-weight:700;margin:18px 0 10px;display:flex;align-items:center;gap:8px}
.chart-section{background:#fff;border-radius:10px;padding:20px;box-shadow:0 1px 3px rgba(0,0,0,.08);margin-bottom:18px}
.chart-section h3{font-size:14px;font-weight:700;margin-bottom:14px;color:#333}
.chart-grid{display:grid;grid-template-columns:1fr 1fr;gap:18px;margin-bottom:18px}
@media(max-width:900px){.chart-grid{grid-template-columns:1fr}}

/* Bar chart */
.bar-chart{display:flex;flex-direction:column;gap:8px}
.bar-row{display:flex;align-items:center;gap:10px}
.bar-label{min-width:70px;font-size:12px;font-weight:600;text-align:right}
.bar-track{flex:1;height:24px;background:#f0f0f0;border-radius:4px;overflow:hidden;display:flex}
.bar-seg{height:100%;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:600;color:#fff;transition:width .5s;min-width:0}
.bar-seg.s-done{background:#8fd4a4}
.bar-seg.s-prog{background:#8ec5f0}
.bar-seg.s-late{background:#f0a0a0}
.bar-seg.s-warn{background:#f5c89a}
.bar-seg.s-todo{background:#d5d5d5}
.bar-value{min-width:40px;font-size:12px;font-weight:600;text-align:left}

/* Pie chart via CSS conic-gradient */
.pie-container{display:flex;gap:20px;align-items:center;flex-wrap:wrap;justify-content:center}
.pie{width:180px;height:180px;border-radius:50%;position:relative}
.pie-center{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:90px;height:90px;background:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;color:#333}
.pie-legend{display:flex;flex-direction:column;gap:6px}
.pie-legend-item{display:flex;align-items:center;gap:6px;font-size:12px}
.pie-legend-dot{width:12px;height:12px;border-radius:2px;flex-shrink:0}

/* Controls */
.ctrl{background:#fff;border-radius:10px;padding:12px 16px;margin-bottom:14px;box-shadow:0 1px 3px rgba(0,0,0,.08);display:flex;gap:14px;align-items:center;flex-wrap:wrap}
.ctrl label{font-size:12px;font-weight:600;color:#555}
.ctrl select{padding:5px 10px;border:1px solid #ccc;border-radius:5px;font-size:12px;font-family:inherit}

/* Table */
.tbl-wrap{background:#fff;border-radius:10px;box-shadow:0 1px 3px rgba(0,0,0,.08);overflow-x:auto;margin-bottom:18px}
table{width:100%;border-collapse:collapse;font-size:12px;white-space:nowrap}
thead th{background:#f5f5f5;padding:8px 6px;text-align:center;font-weight:600;color:#444;border-bottom:2px solid #ddd;position:sticky;top:0;z-index:2}
tbody td{padding:6px 8px;text-align:center;border-bottom:1px solid #eee}
tbody tr:hover{background:#f8f9ff}
td.left{text-align:left}

/* Status badges */
.badge-status{display:inline-block;padding:2px 8px;border-radius:10px;font-size:11px;font-weight:600}
.badge-done{background:#ddf3e4;color:#4a9c6b}
.badge-prog{background:#ddeaf7;color:#5a8fbe}
.badge-late{background:#fce0e0;color:#c06060}
.badge-warn{background:#fdecd5;color:#c08050}
.badge-todo{background:#f0f0f0;color:#aaa}

/* Group header row */
.group-header-row td{background:#ede7f6;color:#7c6bbd;font-weight:700;font-size:13px;padding:10px 12px!important;border-bottom:2px solid #d1c4e9;letter-spacing:0.5px}

/* Priority badges */
.badge-pri{display:inline-block;padding:2px 8px;border-radius:10px;font-size:11px;font-weight:600;cursor:pointer;position:relative}
.badge-p1{background:#fce0e0;color:#c06060}
.badge-p2{background:#fdecd5;color:#c08050}
.badge-p3{background:#ddeaf7;color:#5a8fbe}
.badge-p4{background:#f0f0f0;color:#888}

/* Priority dropdown */
.pri-dropdown{position:absolute;top:100%;left:0;background:#fff;border:1px solid #ddd;border-radius:6px;box-shadow:0 4px 12px rgba(0,0,0,.15);z-index:100;min-width:80px;overflow:hidden}
.pri-dropdown div{padding:6px 12px;font-size:11px;cursor:pointer;font-weight:600}
.pri-dropdown div:hover{background:#e8eaf6}

/* Progress bar */
.prog-bar{width:80px;height:8px;background:#eee;border-radius:4px;overflow:hidden;display:inline-block;vertical-align:middle;margin-right:4px}
.prog-fill{height:100%;border-radius:4px;transition:width .3s}
.prog-fill.pf-done{background:#8fd4a4}
.prog-fill.pf-mid{background:#8ec5f0}
.prog-fill.pf-low{background:#f5c89a}
.prog-fill.pf-zero{background:#eee}

/* KPI */
.kpi-card{background:#fff;border-radius:10px;padding:20px;box-shadow:0 1px 3px rgba(0,0,0,.06);margin-bottom:16px;border-left:4px solid #b0b7e8}
.kpi-card h3{font-size:15px;margin-bottom:4px;color:#6a72b0}
.kpi-card .kpi-weight{font-size:12px;color:#666;margin-bottom:12px}
.kpi-meta{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:14px;font-size:12px}
.kpi-meta dt{font-weight:700;color:#555}
.kpi-meta dd{color:#333;margin-bottom:6px}
.kpi-steps{margin-bottom:14px}
.kpi-steps h4{font-size:12px;font-weight:700;margin-bottom:6px;color:#555}
.kpi-steps li{font-size:12px;margin-bottom:3px;padding-left:4px;list-style:none}
.kpi-steps li:before{content:'';display:inline-block;width:6px;height:6px;background:#1a237e;border-radius:50%;margin-right:6px;vertical-align:middle}
.grade-table{width:100%;border-collapse:collapse;font-size:11px}
.grade-table th,.grade-table td{border:1px solid #ddd;padding:6px 8px;text-align:center}
.grade-table th{background:#f5f5f5;font-weight:700}
.grade-table td:first-child{font-weight:700;width:40px}
.grade-s{background:#e8f5e9;color:#2e7d32}
.grade-a{background:#e3f2fd;color:#1565c0}
.grade-b{background:#fff8e1;color:#f57f17}
.grade-c{background:#fff3e0;color:#e65100}
.grade-d{background:#ffebee;color:#c62828}
.grade-scale{display:flex;gap:0;margin-bottom:18px;border-radius:8px;overflow:hidden}
.grade-scale div{flex:1;text-align:center;padding:8px 4px;font-weight:700;font-size:13px;color:#fff}

/* Weekly report */
.report-section{background:#fff;border-radius:10px;padding:20px;box-shadow:0 1px 3px rgba(0,0,0,.08);margin-bottom:18px}
.report-section h3{font-size:15px;font-weight:700;color:#6a72b0;margin-bottom:4px;border-bottom:2px solid #b0b7e8;padding-bottom:6px}
.report-section h4{font-size:13px;font-weight:700;color:#333;margin:12px 0 6px;padding-left:4px;border-left:3px solid #b0b7e8}
.report-item{font-size:12px;padding:4px 0 4px 16px;line-height:1.6;border-bottom:1px solid #f5f5f5}
.report-item:last-child{border-bottom:none}
.report-highlight{background:#fef3e8;padding:8px 12px;border-radius:6px;margin:8px 0;font-size:12px;border-left:3px solid #f5c89a}
.report-date{font-size:12px;color:#666;margin-bottom:12px}
.btn{padding:8px 18px;border:none;border-radius:6px;cursor:pointer;font-weight:600;font-size:13px;font-family:inherit;transition:.2s}
.btn-primary{background:#1a237e;color:#fff}.btn-primary:hover{background:#283593}
.btn-print{background:#e65100;color:#fff;margin-left:10px}.btn-print:hover{background:#bf360c}

.legend{display:flex;gap:14px;flex-wrap:wrap;margin:10px 0;font-size:11px;color:#666}
.legend-item{display:flex;align-items:center;gap:3px}
.legend-dot{width:10px;height:10px;border-radius:2px}

.footer{text-align:center;color:#999;font-size:11px;padding:20px}

/* Info banner */
.info-banner{background:#e3f2fd;border:1px solid #90caf9;border-radius:8px;padding:10px 16px;margin-bottom:14px;font-size:12px;color:#1565c0;display:flex;align-items:center;gap:10px;flex-wrap:wrap}
.info-banner .info-icon{font-size:16px;flex-shrink:0}
.info-banner .info-text{flex:1}
.btn-refresh{padding:6px 14px;border:1px solid #1565c0;background:#fff;color:#1565c0;border-radius:5px;cursor:pointer;font-weight:600;font-size:12px;font-family:inherit;transition:.2s;white-space:nowrap}
.btn-refresh:hover{background:#1565c0;color:#fff}
.btn-refresh:disabled{opacity:.5;cursor:not-allowed}

/* Loading overlay */
.loading-overlay{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(255,255,255,.85);display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:9999}
.loading-spinner{width:48px;height:48px;border:4px solid #e0e0e0;border-top-color:#1a237e;border-radius:50%;animation:spin 1s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
.loading-text{margin-top:14px;font-size:14px;font-weight:600;color:#1a237e}

/* Error banner */
.error-banner{background:#ffebee;border:1px solid #ef9a9a;border-radius:8px;padding:12px 16px;margin-bottom:14px;font-size:12px;color:#c62828;display:none}

/* Print styles */
@media print{
  body{background:#fff;font-size:11px}
  .header,.tabs,.ctrl,.footer,.info-banner,.error-banner{display:none!important}
  .container{max-width:100%;padding:10px;margin:0}
  .panel{display:none!important}
  .panel.print-target{display:block!important}
  .report-section{box-shadow:none;border:1px solid #ddd;page-break-inside:avoid}
  .btn{display:none!important}
  @page{size:A4;margin:15mm}
}
</style>
</head>
