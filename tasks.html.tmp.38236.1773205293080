<script>
// ============================================================
// GOOGLE SHEETS CONFIG
// ============================================================
const SPREADSHEET_ID = '1zgnxIN0dn1i04rBu-GQwcEZFBmqSX9w-z3w2JGlRMnc';
const SHEET_NAMES = ['1월', '2월', '3월'];

function getSheetURL(sheetName) {
  return `https://docs.google.com/spreadsheets/d/${SPREADSHEET_ID}/gviz/tq?tqx=out:csv&sheet=${encodeURIComponent(sheetName)}`;
}

// ============================================================
// CSV PARSER
// ============================================================
function parseCSV(text) {
  const rows = [];
  let row = []; let field = ''; let inQuote = false;
  for (let i = 0; i < text.length; i++) {
    const c = text[i];
    if (inQuote) {
      if (c === '"' && text[i+1] === '"') { field += '"'; i++; }
      else if (c === '"') { inQuote = false; }
      else { field += c; }
    } else {
      if (c === '"') { inQuote = true; }
      else if (c === ',') { row.push(field.trim()); field = ''; }
      else if (c === '\n' || (c === '\r' && text[i+1] === '\n')) {
        row.push(field.trim()); rows.push(row); row = []; field = '';
        if (c === '\r') i++;
      } else { field += c; }
    }
  }
  if (field || row.length) { row.push(field.trim()); rows.push(row); }
  return rows;
}

// ============================================================
// DATA
// ============================================================
let taskData = [];

// Local priority overrides (persisted in browser session)
const priorityOverrides = {};

function extractMonthNumber(sheetName) {
  const match = sheetName.match(/(\d+)/);
  return match ? parseInt(match[1]) : 0;
}

function parseProgress(val) {
  if (!val) return 0;
  val = val.replace(/"/g, '').replace(/%/g, '').trim();
  if (val === '') return 0;
  const num = parseFloat(val);
  return isNaN(num) ? 0 : Math.round(num);
}

function parseDateStr(val) {
  if (!val) return '';
  val = val.replace(/"/g, '').trim();
  if (val === '') return '';
  // Handle various date formats: 2026-03-01, 2026-3-13, etc.
  const match = val.match(/(\d{4})-(\d{1,2})-(\d{1,2})/);
  if (match) {
    const y = match[1];
    const m = match[2].padStart(2, '0');
    const d = match[3].padStart(2, '0');
    return `${y}-${m}-${d}`;
  }
  return val;
}

function parseSheetData(csvText, monthNumber) {
  const rows = parseCSV(csvText);
  if (rows.length < 2) return [];

  // Skip header row (row 0)
  // Column mapping by position:
  // 0: 구분, 1: 계층, 2: 내용, 3: 담당자, 4: 우선순위,
  // 5: 착수일, 6: 마감일, 7: 진척도, 8: 업무완료일,
  // 9: 상태 설명, 10: 결정필요 사항, 11: 필요 자원, 12: 미팅 요청, 13: 기타/연장

  const tasks = [];
  let currentDept = '';

  for (let i = 1; i < rows.length; i++) {
    const row = rows[i];
    if (!row || row.length < 3) continue;

    const gyeChung = (row[1] || '').trim();
    const content = (row[2] || '').trim();
    const dept = (row[0] || '').trim();

    // Track the current department from 상위 rows
    if (dept) {
      currentDept = dept;
    }

    // Skip rows where 계층 is not "하위"
    if (gyeChung !== '하위') continue;

    // Skip rows where 내용 is empty
    if (!content) continue;

    const owner = (row[3] || '').trim();
    const priority = (row[4] || '').trim();
    const start = parseDateStr(row[5] || '');
    const deadline = parseDateStr(row[6] || '');
    const progress = parseProgress(row[7] || '');
    const completionDate = parseDateStr(row[8] || '');
    const statusDesc = (row[9] || '').trim();
    const decision = (row[10] || '').trim();
    const resource = (row[11] || '').trim();
    const meeting = (row[12] || '').trim();

    const taskDept = dept || currentDept;

    tasks.push({
      month: monthNumber,
      dept: taskDept,
      content: content,
      owner: owner,
      priority: priority || '4순위',
      start: start,
      deadline: deadline,
      progress: progress,
      completionDate: completionDate,
      statusDesc: statusDesc,
      decision: decision,
      resource: resource,
      meeting: meeting
    });
  }

  return tasks;
}

async function fetchSheetData(sheetName) {
  const url = getSheetURL(sheetName);
  const response = await fetch(url);
  if (!response.ok) {
    throw new Error(`시트 "${sheetName}" 로드 실패: HTTP ${response.status}`);
  }
  const text = await response.text();
  const monthNumber = extractMonthNumber(sheetName);
  return parseSheetData(text, monthNumber);
}

async function loadAllData() {
  const loadingEl = document.getElementById('loadingOverlay');
  const errorEl = document.getElementById('errorBanner');
  const refreshBtn = document.getElementById('btnRefresh');

  loadingEl.style.display = 'flex';
  errorEl.style.display = 'none';
  refreshBtn.disabled = true;
  refreshBtn.textContent = '불러오는 중...';

  try {
    const results = await Promise.all(
      SHEET_NAMES.map(name => fetchSheetData(name))
    );

    taskData = [];
    results.forEach(tasks => {
      taskData.push(...tasks);
    });

    // Re-apply local priority overrides
    Object.keys(priorityOverrides).forEach(key => {
      const idx = parseInt(key);
      if (idx >= 0 && idx < taskData.length) {
        // Match by content to be safe
        const override = priorityOverrides[key];
        const matchIdx = taskData.findIndex(t =>
          t.month === override.month && t.content === override.content
        );
        if (matchIdx >= 0) {
          taskData[matchIdx].priority = override.priority;
        }
      }
    });

    populateFilters();
    renderCurrentTab();

    errorEl.style.display = 'none';
  } catch (err) {
    console.error('데이터 로드 오류:', err);
    errorEl.textContent = '데이터 로드 실패: ' + err.message + ' (페이지를 새로고침하거나 잠시 후 다시 시도해주세요)';
    errorEl.style.display = 'block';

    // If we have no data at all, show empty state
    if (taskData.length === 0) {
      populateFilters();
      renderCurrentTab();
    }
  } finally {
    loadingEl.style.display = 'none';
    refreshBtn.disabled = false;
    refreshBtn.textContent = '새로고침';
  }
}

function refreshData() {
  loadAllData();
}

